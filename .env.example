# Copy to .env for local dev; never commit a real .env to git.

DATABASE_URL=postgresql+psycopg2://numquants:numquants_dev@localhost:5433/numquants

# Sessions
JWT_SECRET=dev-secret-CHANGE-ME-in-production-must-exceed-32-bytes
JWT_ALGORITHM=HS256
SESSION_TTL_SECONDS=2592000  # 30 days

# Paystack — get from dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CALLBACK_URL=http://localhost:8501/account

# AI commentary (Enterprise feature)
# LLM_PROVIDER picks which API the commentary service calls. Must be one of:
#   "openai"     — uses OPENAI_API_KEY / OPENAI_MODEL
#   "anthropic"  — uses ANTHROPIC_API_KEY / ANTHROPIC_MODEL
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini  # cheap, fast; switch to gpt-4o for higher quality

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6  # balanced; claude-haiku-4-5 for cost, claude-opus-4-7 for max quality

# Transactional email (Mailgun)
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.numquants.com  # or sandboxXXXX.mailgun.org for testing
MAILGUN_API_BASE=https://api.mailgun.net  # use https://api.eu.mailgun.net for EU
MAIL_FROM=Numquants <hello@mg.numquants.com>

# Public-facing URL for links emitted in emails (password reset, etc.)
APP_BASE_URL=http://localhost:8501
